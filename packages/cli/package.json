{
  "name": "agentsbestfriend",
  "version": "0.1.4",
  "description": "Give your AI coding agents superpowers — a local MCP server for fast, token-efficient code navigation, search & analysis.",
  "type": "module",
  "license": "MIT",
  "author": "Alexander Neitzel (TheRealFloatDev)",
  "repository": {
    "type": "git",
    "url": "https://github.com/TheRealFloatDev/AgentsBestFriend.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/TheRealFloatDev/AgentsBestFriend#readme",
  "bugs": "https://github.com/TheRealFloatDev/AgentsBestFriend/issues",
  "keywords": [
    "mcp",
    "ai",
    "coding-agent",
    "copilot",
    "cursor",
    "claude",
    "code-search",
    "code-navigation",
    "ast",
    "codebase-analysis",
    "model-context-protocol"
  ],
  "bin": {
    "abf": "./dist/index.js",
    "agents-best-friend": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "better-sqlite3": "^12.8.0",
    "commander": "^14.0.3",
    "ts-morph": "^27.0.2"
  },
  "devDependencies": {
    "@abf/core": "workspace:*",
    "@abf/server": "workspace:*",
    "@types/better-sqlite3": "^7.6.13",
    "tsup": "^8.5.1",
    "vitest": "^3.0.0",
    "@types/node": "^20.19.39"
  }
}
