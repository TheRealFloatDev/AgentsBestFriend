{
  "name": "agentsbestfriend",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "abf": "./dist/index.js",
    "agents-best-friend": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
